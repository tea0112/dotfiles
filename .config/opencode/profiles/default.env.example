# OpenCode profile: default (multi-model)
# Copy to default.env and customize

OC_TOP_MODEL=opencode-go/deepseek-v4-flash
OC_PLUGINS='"superpowers@git+https://github.com/obra/superpowers.git","opencode-websearch","oh-my-opencode-slim"'
OC_TUI_PLUGINS='"oh-my-openagent@latest","oh-my-opencode-slim"'
OC_PROVIDER_AIGATEWAY=1

OC_OH_MY_OPENCODE_SLIM_ENABLED=1
OC_OPENAGENT_ENABLED=0

OC_ORCHESTRATOR_MODEL=opencode-go/deepseek-v4-pro
OC_ORACLE_MODEL=opencode-go/mimo-v2.5-pro
OC_LIBRARIAN_MODEL=opencode-go/deepseek-v4-flash
OC_EXPLORER_MODEL=opencode-go/deepseek-v4-flash
OC_DESIGNER_MODEL=opencode-go/kimi-k2.7-code
OC_FIXER_MODEL=opencode-go/deepseek-v4-flash
OC_COUNCIL_MODEL=opencode-go/deepseek-v4-pro
OC_COUNCIL_ALPHA_MODEL=opencode-go/deepseek-v4-pro
OC_COUNCIL_BETA_MODEL=opencode-go/mimo-v2.5-pro
OC_COUNCIL_GAMMA_MODEL=opencode-go/kimi-k2.7-code
OC_COUNCIL_BUGHUNTER_MODEL=opencode-go/deepseek-v4-pro
OC_COUNCIL_ARCHITECT_MODEL=opencode-go/kimi-k2.7-code
OC_COUNCIL_SECURITY_MODEL=opencode-go/mimo-v2.5-pro
OC_COUNCIL_OPTIMIZER_MODEL=opencode-go/qwen3.7-plus

OC_OPENAGENT_MODEL=opencode-go/deepseek-v4-pro
OC_OPENAGENT_SISYPHUS_MODEL=
OC_OPENAGENT_HEPHAESTUS_MODEL=
OC_OPENAGENT_ORACLE_MODEL=
