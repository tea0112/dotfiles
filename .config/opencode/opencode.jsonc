{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/deepseek-v4-pro",
  "mcp": {},
  "tools": {},
  "plugin": [
    "@mohak34/opencode-notifier@latest",
    "superpowers@git+https://github.com/obra/superpowers.git"
  ],
  "agent": {
    // Subagents default to fast model
    "general": {
      "model": "opencode-go/deepseek-v4-flash"
    },
    "explore": {
      "model": "opencode-go/deepseek-v4-flash"
    },
    "scout": {
      "model": "opencode-go/deepseek-v4-flash"
    }
  },
  "autoupdate": true,
  "permission": {
    "bash": {
      // Ask list
      // "*": "ask",
      "git commit *": "ask",
      // Allow list
      "ls *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "cat *": "allow",
      "echo *": "allow",
      "pwd": "allow",
      "date": "allow",
      "grep *": "allow",
      "find *": "allow",
      "wc *": "allow",
      "jq *": "allow",
      "go test *": "allow",
      "go build *": "allow",
      "go mod tidy": "allow",
      "go fmt *": "allow",
      "go vet *": "allow",
      "go list *": "allow",
      "git status": "allow",
      "git log *": "allow",
      "git diff *": "allow",
      "git branch": "allow",
      "git checkout *": "allow",
      "git add *": "allow",
      "git diff *": "allow",
      "git fetch *": "allow",
      "git show *": "allow",
      "git shortlog *": "allow",
      "make lint": "allow",
      "make test": "allow",
      "printf *": "allow",
      // Deny list
      "git push *": "deny",
      "rm *": "ask"
    },
    "edit": "ask"
  }
}
