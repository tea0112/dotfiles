{
  "$schema": "https://opencode.ai/config.json",
  // "model": "opencode-go/deepseek-v4-pro",
  "model": "opencode-go/mimo-v2.5",
  "mcp": {},
  "tools": {},
  "plugin": [
    //"@mohak34/opencode-notifier@latest",
    "superpowers@git+https://github.com/obra/superpowers.git",
  ],
  "provider": {
    "aigateway": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "AI Gateway",
      "options": {
        "baseURL": "{env:AI_GATEWAY_BASE_URL}",
        "apiKey": "{env:AI_GATEWAY_API_KEY}",
      },
      "models": {
        "MiniMax/MiniMax-M2.7": {
          "name": "MiniMax/MiniMax-M2.7",
        },
        "zai-org/GLM-4.7-cc": {
          "name": "zai-org/GLM-4.7-cc",
        },
      },
    },
  },
  "agent": {
    "general": {
      "model": "{env:OPENCODE_AGENT_MODEL}",
      // export MY_AGENT_MODEL="aigateway/MiniMax/MiniMax-M2.7"
      // export OPENCODE_AGENT_MODEL="${MY_AGENT_MODEL:-opencode-go/deepseek-v4-flash}"
    },
    "explore": {
      "model": "{env:OPENCODE_AGENT_MODEL}",
    },
  },
  "autoupdate": true,
  "permission": {
    "bash": {
      // Ask list
      // "*": "ask",
      "git commit *": "ask",
      // Allow list
      "ls *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "cat *": "allow",
      "echo *": "allow",
      "pwd": "allow",
      "date": "allow",
      "grep *": "allow",
      "find *": "allow",
      "wc *": "allow",
      "jq *": "allow",
      "go test *": "allow",
      "go build *": "allow",
      "go mod tidy": "allow",
      "go fmt *": "allow",
      "go vet *": "allow",
      "go list *": "allow",
      "git status": "allow",
      "git log *": "allow",
      "git diff *": "allow",
      "git branch": "allow",
      "git checkout *": "allow",
      "git add *": "allow",
      "git diff *": "allow",
      "git fetch *": "allow",
      "git show *": "allow",
      "git shortlog *": "allow",
      "make lint": "allow",
      "make test": "allow",
      "printf *": "allow",
      // Deny list
      "git push *": "deny",
      "rm *": "ask",
    },
    "edit": "ask",
  },
}
