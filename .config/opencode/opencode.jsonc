{
  "$schema": "https://opencode.ai/config.json",
  // "model": "opencode-go/deepseek-v4-pro",
  // "model": "opencode-go/mimo-v2.5",
  "model": "opencode-go/deepseek-v4-flash",
  "mcp": {},
  "tools": {},
  "plugin": [
    //"@mohak34/opencode-notifier@latest",
    "superpowers@git+https://github.com/obra/superpowers.git",
    "opencode-websearch"
  // "oh-my-openagent@latest" — use oc-heavy for omO
  ],
  "provider": {
    "aigateway": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "AI Gateway",
      "options": {
        "baseURL": "{env:AI_GATEWAY_BASE_URL}",
        "apiKey": "{env:AI_GATEWAY_API_KEY}",
      },
      "models": {
        "MiniMax/MiniMax-M2.7": {
          "name": "MiniMax/MiniMax-M2.7",
        },
        "zai-org/GLM-4.7-cc": {
          "name": "zai-org/GLM-4.7-cc",
        },
      },
    },
  },
  "agent": {
    "general": {
      "model": "{env:OPENCODE_AGENT_MODEL}",
      // export MY_AGENT_MODEL="aigateway/MiniMax/MiniMax-M2.7"
      // export OPENCODE_AGENT_MODEL="${MY_AGENT_MODEL:-opencode-go/deepseek-v4-flash}"
    },
    "explore": {
      "model": "{env:OPENCODE_AGENT_MODEL}",
    },
  },
  "autoupdate": true,
  "permission": {
    "external_directory": "ask",
    "edit": "ask",
    "bash": {
      "git push *": "deny",
      "git push": "deny",
      "rm *": "ask",
      "rm": "ask",
      "*": "allow",
    },
    "*": "allow",
  },
}
