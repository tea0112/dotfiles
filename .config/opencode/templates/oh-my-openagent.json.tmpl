{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "$OC_OPENAGENT_SISYPHUS_MODEL",
      "permission": { "edit": "ask" }
    },
    "hephaestus": {
      "model": "$OC_OPENAGENT_HEPHAESTUS_MODEL"
    },
    "oracle": {
      "model": "$OC_OPENAGENT_ORACLE_MODEL",
      "permission": { "edit": "deny" }
    },
    "explore": {
      "model": "$OC_OPENAGENT_EXPLORE_MODEL",
      "permission": { "edit": "deny" }
    },
    "multimodal-looker": {
      "model": "$OC_OPENAGENT_MULTIMODAL_LOOKER_MODEL"
    },
    "prometheus": {
      "model": "$OC_OPENAGENT_PROMETHEUS_MODEL"
    },
    "metis": {
      "model": "$OC_OPENAGENT_METIS_MODEL"
    },
    "momus": {
      "model": "$OC_OPENAGENT_MOMUS_MODEL"
    },
    "atlas": {
      "model": "$OC_OPENAGENT_ATLAS_MODEL",
      "permission": { "edit": "ask" }
    },
    "sisyphus-junior": {
      "model": "$OC_OPENAGENT_SISYPHUS_JUNIOR_MODEL",
      "permission": { "edit": "ask" }
    }
  },
  "team_mode": {
    "enabled": true,
    "max_parallel_members": 8,
    "max_members": 8,
    "tmux_visualization": false
  },
  "categories": {
    "visual-engineering": {
      "model": "$OC_OPENAGENT_CAT_VISUAL_ENGINEERING_MODEL"
    },
    "ultrabrain": {
      "model": "$OC_OPENAGENT_CAT_ULTRABRAIN_MODEL"
    },
    "deep": {
      "model": "$OC_OPENAGENT_CAT_DEEP_MODEL"
    },
    "artistry": {
      "model": "$OC_OPENAGENT_CAT_ARTISTRY_MODEL"
    },
    "quick": {
      "model": "$OC_OPENAGENT_CAT_QUICK_MODEL"
    },
    "unspecified-low": {
      "model": "$OC_OPENAGENT_CAT_UNSPECIFIED_LOW_MODEL"
    },
    "unspecified-high": {
      "model": "$OC_OPENAGENT_CAT_UNSPECIFIED_HIGH_MODEL"
    },
    "writing": {
      "model": "$OC_OPENAGENT_CAT_WRITING_MODEL"
    }
  }
}
