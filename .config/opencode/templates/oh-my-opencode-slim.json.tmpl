{
  "$schema": "https://unpkg.com/oh-my-opencode-slim@latest/oh-my-opencode-slim.schema.json",
  "preset": "openai",
  "presets": {
    "openai": {
      "orchestrator": {
        "model": "$OC_ORCHESTRATOR_MODEL",
        "variant": "medium",
        "skills": [
          "*"
        ],
        "mcps": [
          "*",
          "!context7"
        ]
      },
      "oracle": {
        "model": "$OC_ORACLE_MODEL",
        "variant": "high",
        "skills": [
          "simplify"
        ],
        "mcps": []
      },
      "librarian": {
        "model": "$OC_LIBRARIAN_MODEL",
        "variant": "low",
        "skills": [],
        "mcps": [
          "websearch",
          "context7",
          "gh_grep"
        ]
      },
      "explorer": {
        "model": "$OC_EXPLORER_MODEL",
        "variant": "low",
        "skills": [],
        "mcps": []
      },
      "designer": {
        "model": "$OC_DESIGNER_MODEL",
        "variant": "medium",
        "skills": [],
        "mcps": []
      },
      "fixer": {
        "model": "$OC_FIXER_MODEL",
        "variant": "low",
        "skills": [],
        "mcps": []
      },
      "council": { "model": "$OC_COUNCIL_MODEL" }
    }
  },
  "council": {
    "default_preset": "aggressive-review",
    "presets": {
      "default": {
        "alpha": { "model": "$OC_COUNCIL_ALPHA_MODEL" },
        "beta": { "model": "$OC_COUNCIL_BETA_MODEL" },
        "gamma": { "model": "$OC_COUNCIL_GAMMA_MODEL" }
      },
      "aggressive-review": {
        "bug-hunter": {
          "model": "$OC_COUNCIL_BUGHUNTER_MODEL",
          "variant": "high",
          "prompt": "Find bugs, edge cases, and failure modes. Flag anything that could crash, corrupt data, or silently fail."
        },
        "architect": {
          "model": "$OC_COUNCIL_ARCHITECT_MODEL",
          "prompt": "Review architecture, boundaries, and long-term design. Identify coupling, wrong abstractions, and maintainability risks."
        },
        "security": {
          "model": "$OC_COUNCIL_SECURITY_MODEL",
          "prompt": "Audit security: injection, auth, data exposure, and unsafe patterns."
        },
        "optimizer": {
          "model": "$OC_COUNCIL_OPTIMIZER_MODEL",
          "prompt": "Focus on performance, latency, and resource usage."
        }
      }
    }
  }
}
